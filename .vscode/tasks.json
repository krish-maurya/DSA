{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile and run",
      "type": "shell",
      "command": "g++ -std=c++17 \"${file}\" -o \"${fileBasenameNoExtension}\" && \"./${fileBasenameNoExtension}\" < input.txt > output.txt",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
